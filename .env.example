DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_bot_application_client_id
GUILD_ID=your_discord_server_id

# Channel where real leaderboard posts should go
MAIN_CHANNEL_ID=main_channel_id

# Channel for test posts
TEST_CHANNEL_ID=test_channel_id

# Optional timezone label in confirmation messages
TIMEZONE=Asia/Amman

# Optional URL to attach as a link button
LEADERBOARD_LINK=

# Optional CS logo image shown at the bottom of the embed
CS_LOGO_URL=

# Default role ID to ping when ping_role=true and role_to_ping is not provided
DEFAULT_MEMBER_ROLE_ID=1465118775715168473
