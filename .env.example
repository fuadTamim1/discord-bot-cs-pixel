DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_bot_application_client_id
GUILD_ID=your_discord_server_id

# Channel where real leaderboard posts should go
MAIN_CHANNEL_ID=main_channel_id

# Optional channel for autonomous meme drops (defaults to MAIN_CHANNEL_ID)
MEME_DROP_CHANNEL_ID=

# Optional local meme folder path (fallback when Supabase vars are missing)
MEME_DROP_FOLDER=data/memes

# Optional Supabase Storage S3 config for meme drops
# If these are set, meme drops are loaded from Supabase instead of local folder.
PIXEL_SUPABASE_BUCKET_ACCESS_KEY=
PIXEL_SUPABASE_BUCKET_SECRET_KEY=
# Backward-compatible typo key name (supported in code if you already use it)
PIXEL_SUPABASE_BUCKET_SECERT_KEY=
PIXEL_SUPABASE_BUCKET_NAME=
PIXEL_SUPABASE_PROJECT_REF=
PIXEL_SUPABASE_S3_REGION=us-east-1
# Optional explicit endpoint override; normally derived from project ref
PIXEL_SUPABASE_S3_ENDPOINT=
# Optional folder prefix inside the bucket (example: memes)
PIXEL_SUPABASE_MEME_PREFIX=

# Channel for test posts
TEST_CHANNEL_ID=test_channel_id

# Optional timezone label in confirmation messages
TIMEZONE=Asia/Amman

# Optional URL to attach as a link button
LEADERBOARD_LINK=

# Optional SQLite path for persistent hype tracking (one hype per user per message)
HYPE_DB_PATH=data/pixel.sqlite

# Optional CS logo image shown at the bottom of the embed
CS_LOGO_URL=

# Default role ID to ping when ping_role=true and role_to_ping is not provided
DEFAULT_MEMBER_ROLE_ID=1465118775715168473
